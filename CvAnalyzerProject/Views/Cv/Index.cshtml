@model CvAnalyzerProject.Entities.CvAnalysis

@{
    ViewBag.Title = "CV Analiz";
    string scoreClass = "bg-danger";

    if (Model != null)
    {
        if (Model.Score >= 80)
        {
            scoreClass = "bg-success";
        }
        else if (Model.Score >= 50)
        {
            scoreClass = "bg-warning text-dark";
        }
    }
}

<div class="card card-custom p-4">
    <h2 class="title-text mb-3">AI Destekli CV Analiz Sistemi</h2>
    <p class="text-muted mt-2">
        ⚡ Yapay zeka ile anında CV analizi
    </p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Error
        </div>
    }

    @using (Html.BeginForm("Analyze", "Cv", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        <div class="mb-3">
            <label class="form-label fw-bold">CV Metni</label>
            <textarea name="CvText" class="form-control" rows="12" placeholder="CV içeriğini buraya yapıştırın"></textarea>

        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">PDF Yükle (Opsiyonel)</label>
            <input type="file" name="pdfFile" class="form-control" accept=".pdf" />
        </div>

        <button type="submit" class="btn btn-primary" onclick="this.innerText='Analiz ediliyor...';">
            Analiz Et
        </button>
        <a href="@Url.Action("History", "Cv")" class="btn btn-outline-secondary ms-2">Geçmiş Analizler</a>
    }
</div>

@if (Model != null)
{
    <div class="card card-custom p-4 mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">📊 Analiz Sonucu</h4>
            <span class="badge @scoreClass score-badge">@Model.Score / 100</span>
        </div>

        <div class="alert alert-info">
            🤖 Bu analiz yapay zeka tarafından oluşturulmuştur.
        </div>

        <p><strong>🧠 Genel Değerlendirme:</strong><br />@Model.GeneralEvaluation</p>
        <p><strong>💪 Güçlü Yönler:</strong><br />@Html.Raw((Model.Strengths ?? "").Replace("\n", "<br/>"))</p>
        <p><strong>⚠️ Zayıf Yönler:</strong><br />@Html.Raw((Model.Weaknesses ?? "").Replace("\n", "<br/>"))</p>
        <p><strong>🚀 Öneriler:</strong><br />@Html.Raw((Model.Suggestions ?? "").Replace("\n", "<br/>"))</p>
        <p><strong>🎯 Uygun Pozisyonlar:</strong><br />@Html.Raw((Model.SuitableRoles ?? "").Replace("\n", "<br/>"))</p>
    </div>
}