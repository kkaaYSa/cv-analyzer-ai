@model List<CvAnalyzerProject.Entities.CvAnalysis>

@{
    ViewBag.Title = "Geçmiş Analizler";
}

<div class="card card-custom p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="title-text mb-0">Geçmiş Analizler</h2>
        <a href="@Url.Action("Index", "Cv")" class="btn btn-primary">Yeni Analiz</a>
    </div>

    <table class="table table-bordered table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Puan</th>
                <th>Tarih</th>
                <th>Genel Değerlendirme</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Count > 0)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td><span class="badge bg-info text-dark">@item.Score</span></td>
                        <td>@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@item.GeneralEvaluation</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">Henüz kayıt yok.</td>
                </tr>
            }
        </tbody>
    </table>
</div>