<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - CV Analyzer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f4f6f9;
        }

        .main-container {
            margin-top: 40px;
            margin-bottom: 40px;
        }

        .card-custom {
            border: none;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }

        .title-text {
            font-weight: 700;
            color: #2c3e50;
        }

        .score-badge {
            font-size: 18px;
            padding: 10px 16px;
            border-radius: 12px;
        }

        textarea.form-control {
            resize: none;
        }
    </style>
</head>
<body>
    <div class="text-center mb-4">
    <h1 style="font-weight:700;">CV Analyzer AI</h1>
</div>
    <div class="container main-container">
        @RenderBody()
    </div>
</body>
</html>